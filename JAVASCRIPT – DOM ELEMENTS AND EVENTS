<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Advanced Currency Converter</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #1e3c72, #2a5298);
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            color: white;
        }

        .container {
            background: rgba(255, 255, 255, 0.1);
            padding: 30px;
            border-radius: 16px;
            width: 350px;
            backdrop-filter: blur(15px);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
            border: 1px solid rgba(255, 255, 255, 0.18);
        }

        h2 {
            text-align: center;
            margin-bottom: 20px;
            font-weight: 600;
        }

        input, select {
            width: 100%;
            padding: 12px;
            margin: 10px 0;
            border-radius: 8px;
            border: none;
            outline: none;
            box-sizing: border-box; /* Ensures padding doesn't affect width */
        }

        button {
            width: 100%;
            padding: 12px;
            background: #00c6ff;
            color: white;
            font-weight: bold;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: background 0.3s ease;
            margin-top: 10px;
        }

        button:hover {
            background: #0072ff;
        }

        .result {
            margin-top: 20px;
            text-align: center;
            font-size: 1.2rem;
            font-weight: 500;
            min-height: 1.5em;
        }
    </style>
</head>
<body onload="initApp()">

<div class="container">
    <h2>Currency Converter</h2>
    
    <form onsubmit="handleSubmit(event)">
        <input type="number" id="amount" placeholder="Enter amount" onkeyup="convert()" step="any">
        
        <select id="from" onchange="convert()">
            <option value="USD">USD - US Dollar</option>
            <option value="INR" selected>INR - Indian Rupee</option>
            <option value="EUR">EUR - Euro</option>
        </select>

        <select id="to" onchange="convert()">
            <option value="USD" selected>USD - US Dollar</option>
            <option value="INR">INR - Indian Rupee</option>
            <option value="EUR">EUR - Euro</option>
        </select>

        <button type="submit">Convert Now</button>
    </form>

    <div class="result" id="result">Enter value</div>
</div>

<script>
    // Global Element Selection
    const amountInput = document.getElementById("amount");
    const resultDiv = document.getElementById("result");
    const fromSelect = document.getElementById("from");
    const toSelect = document.getElementById("to");

    // Hardcoded Exchange Rates (Base: 1 USD)
    const rates = {
        USD: 1,
        INR: 83.00,
        EUR: 0.92
    };

    // Initialize UI on Load
    function initApp() {
        resultDiv.innerHTML = "Waiting for input...";
    }

    // Core Conversion Logic
    function convert() {
        let amount = parseFloat(amountInput.value);
        let from = fromSelect.value;
        let to = toSelect.value;

        // Validation
        if (isNaN(amount) || amount <= 0) {
            resultDiv.innerHTML = "Please enter a valid amount";
            return;
        }

        // Logic: Convert source to USD, then USD to target
        let inUsd = amount / rates[from];
        let convertedAmount = (inUsd * rates[to]).toFixed(2);

        // Update DOM
        resultDiv.innerHTML = `${amount} ${from} = <strong>${convertedAmount} ${to}</strong>`;
    }

    // Handle Form Submit (Prevents page reload)
    function handleSubmit(e) {
        e.preventDefault(); 
        convert();
    }
</script>

</body>
</html>
